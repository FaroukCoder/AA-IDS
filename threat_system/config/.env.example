NVIDIA_API_KEY=your_nvidia_api_key_here
ABUSEIPDB_KEY=your_abuseipdb_api_key_here

# ── Standard model (fast, deterministic JSON, free tier) ──────────────────
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_THINKING=false
LLM_TIMEOUT=60

# ── Thinking/reasoning model — uncomment block below to switch ────────────
# LLM_MODEL=deepseek-ai/deepseek-v4-pro
# LLM_THINKING=true     # enables stream-only mode + extra_body thinking flag
# LLM_TIMEOUT=120       # thinking models need more time before first token
